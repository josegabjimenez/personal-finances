# Your self-hosted Firefly III base URL (no trailing slash).
# Example: https://firefly.mydomain.com
FIREFLY_BASE_URL=

# Personal Access Token created in Firefly III → Profile → OAuth → Personal Access Tokens.
# Stays server-side only — never prefixed with NEXT_PUBLIC_.
FIREFLY_TOKEN=

# Password for the single-user login gate.
APP_PASSWORD=

# 32+ byte random string used to sign the session cookie.
# Generate with: openssl rand -base64 48
AUTH_SECRET=
